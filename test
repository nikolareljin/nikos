#!/usr/bin/env bash
# test — run the NikOS installer in a VirtualBox VM
#
# Usage:
#   ./test                  # run NikOS install on existing VM (default)
#   ./test -b               # rebuild: recreate VM + reinstall OS + run NikOS
#   ./test --build          # same as -b
#   ./test --vm-name=myvm   # override VM name
#
# -b pauses once after OS install so you can type the VM password
# into ssh-copy-id (sets up key-based auth for all subsequent steps).
#
# Dependencies: VirtualBox, curl, ssh-copy-id

set -euo pipefail

# ── Config ────────────────────────────────────────────────────────────────────
VM_NAME="${NIKOS_TEST_VM:-NikOS-test}"
VM_RAM=4096
VM_CPUS=2
VM_DISK=40960        # MB
VM_SSH_PORT=2222
VM_USER="nikos"
VM_PASS="nikos"
VM_HOST="nikos-test-vm.local"

XUBUNTU_ISO="${HOME}/Downloads/xubuntu-24.04.4-desktop-amd64.iso"
XUBUNTU_ISO_URL="https://cdimage.ubuntu.com/xubuntu/releases/24.04/release/xubuntu-24.04.4-desktop-amd64.iso"

SSH_KEY="${HOME}/.ssh/nikos_test_vm"
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
INSTALL_SH_LOCAL="${SCRIPT_DIR}/install.sh"
INSTALL_SH_REMOTE="/tmp/nikos-install.sh"
SOURCE_ARCHIVE_LOCAL="/tmp/nikos-test-src.tar"
SOURCE_ARCHIVE_REMOTE="/tmp/nikos-test-src.tar"
SOURCE_DIR_REMOTE="/home/${VM_USER}/.local/share/nikos"

BUILD=false

for arg in "$@"; do
  case "$arg" in
    -b|--build)   BUILD=true ;;
    --vm-name=*)  VM_NAME="${arg#--vm-name=}" ;;
  esac
done

# ── Helpers ───────────────────────────────────────────────────────────────────
log() { printf '\n[test] %s\n' "$*"; }
die() { printf '\n[test] ERROR: %s\n' "$*" >&2; exit 1; }
hr()  { printf '─%.0s' {1..60}; echo; }

vm_exists()  { VBoxManage showvminfo "$VM_NAME" &>/dev/null; }
vm_running() { VBoxManage showvminfo "$VM_NAME" --machinereadable 2>/dev/null | grep -q 'VMState="running"'; }
vm_off()     { VBoxManage showvminfo "$VM_NAME" --machinereadable 2>/dev/null | grep -qE 'VMState="(poweroff|aborted)"'; }

ensure_ssh_port_forward() {
  local forward_rule="ssh,tcp,,${VM_SSH_PORT},,22"

  if VBoxManage showvminfo "$VM_NAME" --machinereadable 2>/dev/null | grep -Fq "${forward_rule}"; then
    return 0
  fi

  log "Configuring SSH port forward localhost:${VM_SSH_PORT} -> ${VM_NAME}:22..."
  if vm_running; then
    VBoxManage controlvm "${VM_NAME}" natpf1 delete ssh &>/dev/null || true
    VBoxManage controlvm "${VM_NAME}" natpf1 "${forward_rule}"
  else
    VBoxManage modifyvm "${VM_NAME}" --natpf1 delete ssh &>/dev/null || true
    VBoxManage modifyvm "${VM_NAME}" --natpf1 "${forward_rule}"
  fi
}

wait_for_ssh_port() {
  log "Waiting for SSH port on localhost:${VM_SSH_PORT}..."
  attempts=0
  until bash -c "exec 3<>/dev/tcp/127.0.0.1/${VM_SSH_PORT}" &>/dev/null; do
    attempts=$((attempts + 1))
    [[ $attempts -gt 72 ]] && die "SSH port ${VM_SSH_PORT} never opened. Check that the VM is running and the NAT port forward exists."
    sleep 5
  done
  log "SSH port is open."
}

wait_for_ssh_key_auth() {
  log "Waiting for key-based SSH login..."
  local attempts=0 key_copied=false
  until ssh -o StrictHostKeyChecking=no -o ConnectTimeout=5 -o BatchMode=yes \
        -i "${SSH_KEY}" -p "${VM_SSH_PORT}" "${VM_USER}@localhost" "echo ok" &>/dev/null; do
    attempts=$((attempts + 1))
    # After ~30 s without key auth, try a one-shot auto-copy via sshpass
    if [[ $attempts -gt 6 && "${key_copied}" == "false" ]]; then
      log "Key auth not ready — auto-copying SSH key with sshpass..."
      sshpass -p "${VM_PASS}" ssh-copy-id -i "${SSH_KEY}.pub" \
        -o StrictHostKeyChecking=no \
        -p "${VM_SSH_PORT}" "${VM_USER}@localhost" 2>/dev/null && key_copied=true || true
      attempts=0
    elif [[ $attempts -gt 12 ]]; then
      die "SSH is reachable but key-based login could not be established. Verify the VM password or run: ssh-copy-id -i ${SSH_KEY}.pub -p ${VM_SSH_PORT} ${VM_USER}@localhost"
    fi
    sleep 5
  done
  log "SSH ready."
}

# Install openssh-server on the VM via VirtualBox Guest Additions.
# Xubuntu Desktop ISO does not ship openssh-server; --install-additions
# makes guestcontrol available once the VM has booted after the OS install.
install_openssh_server() {
  log "Waiting for Guest Additions to become ready..."
  local attempts=0
  until VBoxManage guestcontrol "${VM_NAME}" stat \
        --username "${VM_USER}" --password "${VM_PASS}" \
        "/" &>/dev/null 2>&1; do
    attempts=$((attempts + 1))
    [[ $attempts -gt 48 ]] && die "Guest Additions not ready after 4 min — cannot install openssh-server. Ensure --install-additions succeeded."
    sleep 5
    printf '.'
  done
  echo
  log "Installing openssh-server via guest control..."
  VBoxManage guestcontrol "${VM_NAME}" run \
    --exe /bin/bash \
    --username "${VM_USER}" --password "${VM_PASS}" \
    --wait-stdout --wait-stderr \
    -- -c "echo '${VM_PASS}' | sudo -S apt-get install -y openssh-server 2>&1 \
           && sudo systemctl enable --now ssh 2>&1"
  log "openssh-server installed and started."
}

wait_for_ssh() {
  wait_for_ssh_port
  wait_for_ssh_key_auth
}

vm_ssh() {
  ssh -o StrictHostKeyChecking=no \
      -i "${SSH_KEY}" \
      -p "${VM_SSH_PORT}" \
      "${VM_USER}@localhost" "$@"
}

vm_ssh_tty() {
  ssh -tt -o StrictHostKeyChecking=no \
      -i "${SSH_KEY}" \
      -p "${VM_SSH_PORT}" \
      "${VM_USER}@localhost" "$@"
}

vm_scp() {
  scp -o StrictHostKeyChecking=no \
      -i "${SSH_KEY}" \
      -P "${VM_SSH_PORT}" \
      "$@"
}

run_installer() {
  [[ -f "${INSTALL_SH_LOCAL}" ]] || die "Local installer not found at ${INSTALL_SH_LOCAL}"

  log "Packaging local NikOS source tree..."
  tar -C "${SCRIPT_DIR}" \
    --exclude='./.git' \
    --exclude='./PLAN.md' \
    --exclude='./TODO.txt' \
    -cf "${SOURCE_ARCHIVE_LOCAL}" .

  log "Staging local NikOS source tree in VM..."
  vm_ssh "rm -rf '${SOURCE_DIR_REMOTE}' '${SOURCE_ARCHIVE_REMOTE}' && mkdir -p '$(dirname "${SOURCE_DIR_REMOTE}")'"
  vm_scp "${SOURCE_ARCHIVE_LOCAL}" "${VM_USER}@localhost:${SOURCE_ARCHIVE_REMOTE}"

  log "Copying local installer to VM..."
  vm_scp "${INSTALL_SH_LOCAL}" "${VM_USER}@localhost:${INSTALL_SH_REMOTE}"

  vm_ssh "mkdir -p '${SOURCE_DIR_REMOTE}' && tar -xf '${SOURCE_ARCHIVE_REMOTE}' -C '${SOURCE_DIR_REMOTE}'"

  hr
  log "Running NikOS installer in the VM."
  log "You will be prompted for the VM sudo password: '${VM_PASS}'"
  hr
  log "Running NikOS installer..."
  vm_ssh_tty "chmod +x '${INSTALL_SH_REMOTE}' && NIKOS_HOME='${SOURCE_DIR_REMOTE}' NIKOS_SKIP_REPO_SYNC=1 bash '${INSTALL_SH_REMOTE}'"
}

# ── Preflight ─────────────────────────────────────────────────────────────────
command -v VBoxManage  &>/dev/null || die "VirtualBox not found"
command -v curl        &>/dev/null || die "curl not found"
command -v scp         &>/dev/null || die "scp not found (install openssh-client)"
command -v ssh-copy-id &>/dev/null || die "ssh-copy-id not found (install openssh-client)"
command -v sshpass     &>/dev/null || die "sshpass not found (install sshpass)"

# ── SSH key ───────────────────────────────────────────────────────────────────
if [[ ! -f "${SSH_KEY}" ]]; then
  log "Generating SSH key → ${SSH_KEY}"
  ssh-keygen -t ed25519 -f "${SSH_KEY}" -N "" -C "nikos-test-vm"
fi

# ── Phase 1: Create VM and install OS (unattended) ────────────────────────────
if $BUILD; then

  # ISO
  if [[ ! -f "${XUBUNTU_ISO}" ]] || [[ $(stat -c%s "${XUBUNTU_ISO}") -lt 1000000000 ]]; then
    log "Downloading Xubuntu 24.04 ISO (~4 GB)..."
    curl -L "${XUBUNTU_ISO_URL}" -o "${XUBUNTU_ISO}" --progress-bar
  fi
  log "ISO ready: ${XUBUNTU_ISO}"

  # Wipe existing VM
  if vm_exists; then
    log "Removing existing VM '${VM_NAME}'..."
    vm_running && VBoxManage controlvm "${VM_NAME}" poweroff && sleep 3
    VBoxManage unregistervm "${VM_NAME}" --delete
  fi
  # Remove leftover VM directory (unregistervm --delete removes disks but
  # may leave the settings directory behind, causing createvm to fail)
  vm_dir="${HOME}/VirtualBox VMs/${VM_NAME}"
  if [[ -d "${vm_dir}" ]]; then
    log "Removing leftover VM directory: ${vm_dir}"
    rm -rf "${vm_dir}"
  fi

  # Create VM
  log "Creating VM '${VM_NAME}'  (RAM: ${VM_RAM} MB, CPUs: ${VM_CPUS}, Disk: ${VM_DISK} MB)"
  VBoxManage createvm --name "${VM_NAME}" --ostype Ubuntu_64 --register

  VBoxManage modifyvm "${VM_NAME}" \
    --memory "${VM_RAM}" \
    --cpus "${VM_CPUS}" \
    --boot1 dvd --boot2 disk --boot3 none \
    --nic1 nat \
    --natpf1 "ssh,tcp,,${VM_SSH_PORT},,22" \
    --audio none \
    --graphicscontroller vmsvga \
    --vram 32

  disk="${HOME}/VirtualBox VMs/${VM_NAME}/${VM_NAME}.vdi"
  VBoxManage createmedium disk --filename "${disk}" --size "${VM_DISK}" --format VDI
  VBoxManage storagectl "${VM_NAME}" --name SATA --add sata --controller IntelAhci
  VBoxManage storageattach "${VM_NAME}" \
    --storagectl SATA --port 0 --device 0 --type hdd --medium "${disk}"

  # Unattended OS install — VirtualBox handles preseed, no GUI needed
  log "Starting unattended Xubuntu install (headless) — this takes ~10-15 min..."
  VBoxManage unattended install "${VM_NAME}" \
    --iso="${XUBUNTU_ISO}" \
    --user="${VM_USER}" \
    --password="${VM_PASS}" \
    --hostname="${VM_HOST}" \
    --country=US \
    --time-zone=UTC \
    --locale=en_US \
    --install-additions \
    --start-vm=headless

  # Wait for the installer to complete (VM powers off when done)
  sleep 30
  dots=0
  while ! vm_off; do
    sleep 15
    dots=$((dots + 1))
    printf '.'
    [[ $dots -gt 80 ]] && die "Unattended install timed out (20 min)"
  done
  echo  # newline after progress dots

  log "OS install complete. Starting VM..."
  VBoxManage startvm "${VM_NAME}" --type headless

  # ── Phase 2: Install openssh-server and copy SSH key (non-interactive) ──────
  install_openssh_server
  wait_for_ssh_port
  log "Copying SSH public key to VM (non-interactive)..."
  sshpass -p "${VM_PASS}" ssh-copy-id -i "${SSH_KEY}.pub" \
    -o StrictHostKeyChecking=no \
    -p "${VM_SSH_PORT}" \
    "${VM_USER}@localhost"
  log "Key copied. All further access is key-based."
fi

# ── Phase 3: Ensure VM is running ────────────────────────────────────────────
vm_exists || die "VM '${VM_NAME}' does not exist. Run './test -b' first."

if ! vm_running; then
  log "Starting VM '${VM_NAME}'..."
  VBoxManage startvm "${VM_NAME}" --type headless
fi

ensure_ssh_port_forward

# ── Phase 4: SSH in and run NikOS installer ───────────────────────────────────
wait_for_ssh

run_installer

# ── Phase 5: Verify ───────────────────────────────────────────────────────────
log "═══ nikos doctor ═══"
vm_ssh "nikos doctor" || true

hr
log "═══ Verification checklist ═══"
checks=(
  "command -v code"
  "code --list-extensions 2>/dev/null | grep -q arcticicestudio"
  "command -v ollama"
  "command -v lantern"
  "test -d /usr/share/themes/Nordic"
  "test -d /usr/share/icons/Papirus-Dark"
  "test -f /usr/share/nikos/wallpaper.png"
  "test -f /usr/share/nikos/logo.png"
  "test -f /usr/share/nikos/logo.svg"
  "test -f /usr/share/plymouth/themes/nikos/nikos.plymouth"
  "test -f /usr/share/plymouth/themes/nikos/nikos-logo.png"
  "grep -q 'Theme=nikos' /etc/plymouth/plymouthd.conf"
  "test -f /etc/X11/default-display-manager && grep -qx '/usr/sbin/lightdm' /etc/X11/default-display-manager"
)

pass=0; fail=0
for c in "${checks[@]}"; do
  if vm_ssh "${c}" &>/dev/null; then
    echo "  [✓] ${c}"; pass=$((pass + 1))
  else
    echo "  [✗] ${c}"; fail=$((fail + 1))
  fi
done

hr
log "Results: ${pass} passed, ${fail} failed"
[[ $fail -eq 0 ]] && log "All checks passed — NikOS is good." \
                  || log "Some checks failed — review output above."
