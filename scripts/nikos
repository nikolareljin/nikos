#!/usr/bin/env bash
set -euo pipefail

NIKOS_VERSION="0.2.1"
NIKOS_HOME="${NIKOS_HOME:-${HOME}/.local/share/nikos}"
NIKOS_CONFIG_DIR="${HOME}/.config/nikos"
SELECTIONS_FILE="${NIKOS_CONFIG_DIR}/selected-options.env"
HELPERS="${NIKOS_HOME}/scripts/script-helpers/helpers.sh"
REPO_SYNC_HELPERS="${NIKOS_HOME}/scripts/repo-sync.sh"
# Used by sourced repo sync helpers.
# shellcheck disable=SC2034
MAIN_VARS_REL="vars/main.yml"
# shellcheck disable=SC2034
LOCAL_VARS_REL="vars/local.yml"
ANSIBLE_REQUIREMENTS="${NIKOS_HOME}/requirements.yml"

# Source script-helpers if available (installed via submodule)
if [[ -f "${HELPERS}" ]]; then
  # shellcheck source=/dev/null
  source "${HELPERS}"
  shlib_import logging
else
  # Minimal fallback: plain print functions so the rest of the script is uniform
  print_info()    { echo "[info] $*"; }
  print_error()   { echo "[error] $*" >&2; }
  print_success() { echo "[ok] $*"; }
  print_warn()    { echo "[warn] $*"; }
fi

if [[ -f "${REPO_SYNC_HELPERS}" ]]; then
  # shellcheck source=/dev/null
  source "${REPO_SYNC_HELPERS}"
fi

usage() {
  cat <<EOF
nikos ${NIKOS_VERSION} — Neural Innovation for Knowledge OS

Usage:
  nikos setup            Run full NikOS playbook (first install)
  nikos update           git pull + re-run playbook (idempotent)
  nikos add <name>       Install optional role: network | music | education
  nikos status           Show NikOS version, Ollama models, installed roles
  nikos doctor           Check for broken configs and missing dependencies
  nikos help             Show this message
EOF
}

_get_default_skip_tags() {
  local skip_tags="${NIKOS_SKIP_TAGS:-}"

  if [[ -n "${skip_tags}" ]]; then
    printf '%s\n' "${skip_tags#,}"
    return 0
  fi

  if [[ -f "${SELECTIONS_FILE}" ]]; then
    # shellcheck source=/dev/null
    source "${SELECTIONS_FILE}"
    printf '%s\n' "${NIKOS_SKIP_TAGS_SAVED:-}"
  else
    printf '\n'
  fi

  return 0
}

_save_skip_tags() {
  mkdir -p "${NIKOS_CONFIG_DIR}"
  printf 'NIKOS_SKIP_TAGS_SAVED=%q\n' "${1}" > "${SELECTIONS_FILE}"
}

_remove_skip_tag() {
  local tag="$1"
  local skip_tags item
  local updated=()

  skip_tags="$(_get_default_skip_tags)"
  IFS=, read -r -a items <<< "${skip_tags}"
  for item in "${items[@]}"; do
    [[ -z "${item}" || "${item}" == "${tag}" ]] && continue
    updated+=("${item}")
  done

  _save_skip_tags "$(IFS=,; echo "${updated[*]}")"
}

_playbook() {
  local extra_args=("$@")
  local skip_tags=""
  local playbook_args=(
    -i "${NIKOS_HOME}/inventory/local"
    "${NIKOS_HOME}/site.yml"
    --ask-become-pass
  )
  if [[ ! -d "${NIKOS_HOME}/.git" ]]; then
    print_error "NikOS repo not found at ${NIKOS_HOME}. Run the installer first."
    exit 1
  fi
  if [[ ! -f "${ANSIBLE_REQUIREMENTS}" ]]; then
    print_error "Ansible collection requirements file not found at ${ANSIBLE_REQUIREMENTS}."
    exit 1
  fi
  print_info "Installing required Ansible collections..."
  ansible-galaxy collection install -r "${ANSIBLE_REQUIREMENTS}"
  skip_tags="$(_get_default_skip_tags)"
  [[ -n "${skip_tags}" ]] && playbook_args+=(--skip-tags "${skip_tags}")
  playbook_args+=("${extra_args[@]}")
  (
    cd "${NIKOS_HOME}"
    ANSIBLE_CONFIG="${NIKOS_HOME}/ansible.cfg" ansible-playbook "${playbook_args[@]}"
  )
}

cmd_setup() {
  print_info "Running full NikOS setup..."
  _playbook
}

cmd_update() {
  local update_rc=0
  print_info "Updating NikOS repo and submodules..."
  if [[ -d "${NIKOS_HOME}/.git" ]]; then
    if ! declare -F _pull_repo_updates >/dev/null; then
      print_error "Repo sync helpers not found at ${REPO_SYNC_HELPERS}. Reinstall NikOS or restore that file."
      exit 1
    fi
    if _pull_repo_updates "nikos-update-autostash"; then
      :
    else
      update_rc=$?
      case "${update_rc}" in
        1)
          print_error "Updates were pulled, but local changes did not reapply cleanly. Resolve the git conflicts in ${NIKOS_HOME}, then rerun 'nikos update'."
          ;;
        2)
          print_error "Failed to pull updates for ${NIKOS_HOME}. Review the git output above, resolve the issue, then rerun 'nikos update'."
          ;;
        3)
          print_error "Failed to update git submodules in ${NIKOS_HOME}. Review the git output above, resolve the issue, then rerun 'nikos update'."
          ;;
        *)
          print_error "Failed to update NikOS repo and submodules in ${NIKOS_HOME}. Review the git output above, then rerun 'nikos update'."
          ;;
      esac
      exit 1
    fi
  else
    print_error "NikOS repo not found at ${NIKOS_HOME}. Run the installer first."
    exit 1
  fi
  print_info "Re-running playbook..."
  _playbook
}

cmd_add() {
  local role="${1:-}"
  case "${role}" in
    network | music | education)
      print_info "Installing optional bundle: ${role}"
      _remove_skip_tag "${role}"
      _playbook --tags "${role}"
      ;;
    *)
      print_error "Unknown optional role: ${role}"
      echo "Available: network, music, education"
      exit 1
      ;;
  esac
}

cmd_status() {
  print_info "NikOS ${NIKOS_VERSION} — Neural Innovation for Knowledge OS"
  echo ""
  echo "Ollama models:"
  ollama list 2>/dev/null || echo "  Ollama not running"
  echo ""
  echo "distrodeck:"
  distrodeck --version 2>/dev/null || echo "  distrodeck not found"
  echo ""
  echo "conda environments:"
  "${HOME}/miniforge3/bin/conda" env list 2>/dev/null || echo "  conda not found"
  echo ""
  if [[ -d "${NIKOS_HOME}/.git" ]]; then
    echo "Repo: ${NIKOS_HOME} ($(git -C "${NIKOS_HOME}" rev-parse --short HEAD 2>/dev/null || echo 'unknown'))"
  fi
}

cmd_doctor() {
  local issues=0
  conda_env_exists() {
    local conda_bin="$1"
    test -f "${conda_bin}" && "${conda_bin}" env list | grep -q nikos-ai
  }
  check() {
    local label="$1"
    shift
    if "$@" &>/dev/null; then
      print_success "${label}"
    else
      print_error "${label}"
      issues=$((issues + 1))
    fi
  }
  optional_check() {
    local label="$1"
    shift
    if "$@" &>/dev/null; then
      print_success "${label}"
    else
      print_warn "${label} (optional or pending first login)"
    fi
  }
  print_info "NikOS Doctor — checking system health..."
  check "ansible installed" command -v ansible-playbook
  check "dialog installed" command -v dialog
  check "gh CLI installed" command -v gh
  check "Ollama installed" command -v ollama
  check "VS Code installed" command -v code
  check "distrodeck installed" command -v distrodeck
  optional_check "conda installed" test -f "${HOME}/miniforge3/bin/conda"
  optional_check "nikos-ai env exists" conda_env_exists "${HOME}/miniforge3/bin/conda"
  optional_check "Claude Code installed" command -v claude
  optional_check "Gemini CLI installed" command -v gemini
  check "Nordic GTK theme" test -d /usr/share/themes/Nordic
  check "Papirus icons" test -d /usr/share/icons/Papirus-Dark
  optional_check "GitHub configured" test -f "${HOME}/.config/nikos/github-configured"
  check "NikOS repo present" test -d "${NIKOS_HOME}/.git"
  check "script-helpers present" test -f "${HELPERS}"
  echo ""
  if [[ ${issues} -eq 0 ]]; then
    print_success "All checks passed."
  else
    print_error "${issues} issue(s) found. Run 'nikos update' to attempt repair."
  fi
}

case "${1:-help}" in
  setup)  cmd_setup ;;
  update) cmd_update ;;
  add)    cmd_add "${2:-}" ;;
  status) cmd_status ;;
  doctor) cmd_doctor ;;
  help | --help | -h) usage ;;
  *)
    print_error "Unknown command: ${1}"
    usage
    exit 1
    ;;
esac
