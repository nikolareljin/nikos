#!/usr/bin/env bash
set -euo pipefail

NIKOS_VERSION="0.2.0"
NIKOS_HOME="${HOME}/.local/share/nikos"
HELPERS="${NIKOS_HOME}/scripts/script-helpers/helpers.sh"
MAIN_VARS_REL="vars/main.yml"
LOCAL_VARS_REL="vars/local.yml"

# Source script-helpers if available (installed via submodule)
if [[ -f "${HELPERS}" ]]; then
  # shellcheck source=/dev/null
  source "${HELPERS}"
  shlib_import logging
else
  # Minimal fallback: plain print functions so the rest of the script is uniform
  print_info()    { echo "[info] $*"; }
  print_error()   { echo "[error] $*" >&2; }
  print_success() { echo "[ok] $*"; }
fi

usage() {
  cat <<EOF
nikos ${NIKOS_VERSION} — Neural Innovation for Knowledge OS

Usage:
  nikos setup            Run full NikOS playbook (first install)
  nikos update           git pull + re-run playbook (idempotent)
  nikos add <name>       Install optional role: network | music | education
  nikos status           Show NikOS version, Ollama models, installed roles
  nikos doctor           Check for broken configs and missing dependencies
  nikos help             Show this message
EOF
}

_playbook() {
  local extra_args=("$@")
  if [[ ! -d "${NIKOS_HOME}/.git" ]]; then
    print_error "NikOS repo not found at ${NIKOS_HOME}. Run the installer first."
    exit 1
  fi
  (
    cd "${NIKOS_HOME}"
    ANSIBLE_CONFIG="${NIKOS_HOME}/ansible.cfg" ansible-playbook \
      -i "${NIKOS_HOME}/inventory/local" "${NIKOS_HOME}/site.yml" \
      --ask-become-pass "${extra_args[@]}"
  )
}

_migrate_local_vars() {
  local main_vars_path="${NIKOS_HOME}/${MAIN_VARS_REL}"
  local local_vars_path="${NIKOS_HOME}/${LOCAL_VARS_REL}"

  if [[ -f "${local_vars_path}" ]]; then
    return
  fi

  if ! git -C "${NIKOS_HOME}" diff --quiet -- "${MAIN_VARS_REL}" || \
     ! git -C "${NIKOS_HOME}" diff --cached --quiet -- "${MAIN_VARS_REL}"; then
    print_info "Migrating local vars/main.yml customizations to vars/local.yml..."
    cp "${main_vars_path}" "${local_vars_path}"
    git -C "${NIKOS_HOME}" restore --staged --worktree --source=HEAD -- "${MAIN_VARS_REL}"
  fi
}

_pull_repo_updates() {
  local stash_ref=""

  _migrate_local_vars

  if ! git -C "${NIKOS_HOME}" diff --quiet || \
     ! git -C "${NIKOS_HOME}" diff --cached --quiet || \
     [[ -n "$(git -C "${NIKOS_HOME}" ls-files --others --exclude-standard)" ]]; then
    print_info "Temporarily stashing local changes before pulling updates..."
    git -C "${NIKOS_HOME}" stash push --include-untracked --message "nikos-update-autostash" >/dev/null
    stash_ref="stash@{0}"
  fi

  git -C "${NIKOS_HOME}" pull --ff-only
  git -C "${NIKOS_HOME}" submodule update --init --recursive

  if [[ -n "${stash_ref}" ]]; then
    print_info "Re-applying local changes..."
    if ! git -C "${NIKOS_HOME}" stash pop --index "${stash_ref}" >/dev/null; then
      print_error "Updates were pulled, but local changes did not reapply cleanly. Resolve the git conflicts in ${NIKOS_HOME}, then rerun 'nikos update'."
      exit 1
    fi
  fi
}

cmd_setup() {
  print_info "Running full NikOS setup..."
  _playbook
}

cmd_update() {
  print_info "Updating NikOS repo and submodules..."
  if [[ -d "${NIKOS_HOME}/.git" ]]; then
    _pull_repo_updates
  else
    print_error "NikOS repo not found at ${NIKOS_HOME}. Run the installer first."
    exit 1
  fi
  print_info "Re-running playbook..."
  _playbook
}

cmd_add() {
  local role="${1:-}"
  case "${role}" in
    network | music | education)
      print_info "Installing optional bundle: ${role}"
      _playbook --tags "${role}"
      ;;
    *)
      print_error "Unknown optional role: ${role}"
      echo "Available: network, music, education"
      exit 1
      ;;
  esac
}

cmd_status() {
  print_info "NikOS ${NIKOS_VERSION} — Neural Innovation for Knowledge OS"
  echo ""
  echo "Ollama models:"
  ollama list 2>/dev/null || echo "  Ollama not running"
  echo ""
  echo "distrodeck:"
  distrodeck --version 2>/dev/null || echo "  distrodeck not found"
  echo ""
  echo "conda environments:"
  "${HOME}/miniforge3/bin/conda" env list 2>/dev/null || echo "  conda not found"
  echo ""
  if [[ -d "${NIKOS_HOME}/.git" ]]; then
    echo "Repo: ${NIKOS_HOME} ($(git -C "${NIKOS_HOME}" rev-parse --short HEAD 2>/dev/null || echo 'unknown'))"
  fi
}

cmd_doctor() {
  local issues=0
  check() {
    local label="$1" cmd="$2"
    if eval "${cmd}" &>/dev/null; then
      print_success "${label}"
    else
      print_error "${label}"
      issues=$((issues + 1))
    fi
  }
  print_info "NikOS Doctor — checking system health..."
  check "ansible installed"       "command -v ansible-playbook"
  check "dialog installed"        "command -v dialog"
  check "gh CLI installed"        "command -v gh"
  check "Ollama installed"        "command -v ollama"
  check "VS Code installed"       "command -v code"
  check "distrodeck installed"    "command -v distrodeck"
  check "conda installed"         "test -f ${HOME}/miniforge3/bin/conda"
  check "nikos-ai env exists"     "${HOME}/miniforge3/bin/conda env list | grep -q nikos-ai"
  check "Claude Code installed"   "command -v claude"
  check "Gemini CLI installed"    "command -v gemini"
  check "Nordic GTK theme"        "test -d /usr/share/themes/Nordic"
  check "Papirus icons"           "test -d /usr/share/icons/Papirus-Dark"
  check "GitHub configured"       "test -f ${HOME}/.config/nikos/github-configured"
  check "NikOS repo present"      "test -d ${NIKOS_HOME}/.git"
  check "script-helpers present"  "test -f ${HELPERS}"
  echo ""
  if [[ ${issues} -eq 0 ]]; then
    print_success "All checks passed."
  else
    print_error "${issues} issue(s) found. Run 'nikos update' to attempt repair."
  fi
}

case "${1:-help}" in
  setup)  cmd_setup ;;
  update) cmd_update ;;
  add)    cmd_add "${2:-}" ;;
  status) cmd_status ;;
  doctor) cmd_doctor ;;
  help | --help | -h) usage ;;
  *)
    print_error "Unknown command: ${1}"
    usage
    exit 1
    ;;
esac
